{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "gbl-corpus-coder",
  "main": "./worker/index.js",
  "compatibility_date": "2026-06-09",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "kv_namespaces": [
    {
      "binding": "ARTICLE_CODING"
    }
  ]
}
